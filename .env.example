# Infra local (Docker Compose em docker/docker-compose.yml)
# Portas no HOST: Postgres 5432, Redis 6379, MinIO API 9000, Console 9001

DATABASE_URL="postgresql://vrumcar:vrumcar_dev_password@localhost:5432/vrumcar?schema=public"
REDIS_URL="redis://localhost:6379"

# Storage (S3-compatible: MinIO local ou AWS S3 em produção)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="vrumcar-photos"
S3_ACCESS_KEY="minio"
S3_SECRET_KEY="minio_dev_password"
S3_PUBLIC_URL="http://localhost:9000/vrumcar-photos"
S3_FORCE_PATH_STYLE="true"

# Encryption key for sensitive credentials (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Auth.js v5 — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Email (Resend) — opcional; se vazio, magic link fica desligado
RESEND_API_KEY=""
EMAIL_FROM="noreply@vrumcar.local"
