generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  SALES
  FINANCE
  VIEWER

  @@map("org_role")
}

model Plan {
  id                 String   @id @default(cuid()) @map("id")
  slug               String   @unique @map("slug")
  name               String   @map("name")
  monthlyPriceCents  Int      @map("monthly_price_cents")
  yearlyPriceCents   Int      @map("yearly_price_cents")
  maxUsers           Int      @map("max_users")
  maxVehicles        Int      @map("max_vehicles")
  maxWhatsappMsgs    Int      @map("max_whatsapp_msgs")
  features           Json     @default("{}") @map("features")
  isPublic           Boolean  @default(true) @map("is_public")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Organization {
  id          String    @id @default(cuid()) @map("id")
  slug        String    @unique @map("slug")
  name        String    @map("name")
  legalName   String?   @map("legal_name")
  cnpj        String?   @map("cnpj")
  phone       String?   @map("phone")
  email       String?   @map("email")
  address     Json?     @map("address")
  logoUrl     String?   @map("logo_url")
  timezone    String    @default("America/Sao_Paulo") @map("timezone")
  status      String    @default("ACTIVE") @map("status")
  trialEndsAt DateTime? @map("trial_ends_at")
  maxChannelInstances Int     @default(3) @map("max_channel_instances")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  memberships    Membership[]
  subscription   Subscription?
  invitations    Invitation[]
  vehicles       Vehicle[]
  vehiclePhotos     VehiclePhoto[]
  vehicleCosts      VehicleCost[]
  vehiclePrices     VehiclePriceHistory[]
  leads             Lead[]
  leadInteractions  LeadInteraction[]
  customers         Customer[]
  sales             Sale[]
  channelInstances ChannelInstance[]
  conversations    Conversation[]
  messages         Message[]

  @@index([status])
  @@map("organizations")
}

model Subscription {
  id                 String   @id @default(cuid()) @map("id")
  organizationId     String   @unique @map("organization_id")
  planId             String   @map("plan_id")
  status             String   @map("status")
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  cancelAtPeriodEnd  Boolean  @default(false) @map("cancel_at_period_end")
  externalId         String?  @map("external_id")
  externalProvider   String?  @map("external_provider")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model User {
  id            String    @id @default(cuid()) @map("id")
  email         String    @unique @map("email")
  name          String    @map("name")
  passwordHash  String?   @map("password_hash")
  emailVerified DateTime? @map("email_verified")
  avatarUrl     String?   @map("avatar_url")
  totpSecret    String?   @map("totp_secret")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts        Account[]
  sessions        Session[]
  memberships     Membership[] @relation("MembershipUser")
  invitationsSent Invitation[] @relation("InvitationInvitedBy")
  assignedLeads   Lead[]       @relation("LeadAssignedTo")
  sales           Sale[]       @relation("SalesSalesPerson")
  assignedConversations Conversation[] @relation("ConversationAssignedTo")
  sentMessages          Message[]      @relation("MessageSentBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid()) @map("id")
  userId            String  @map("user_id")
  provider          String  @map("provider")
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String? @map("scope")
  idToken           String? @map("id_token")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid()) @map("id")
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @map("expires")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime @map("expires")

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Membership {
  id             String   @id @default(cuid()) @map("id")
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           OrgRole  @map("role")
  isActive       Boolean  @default(true) @map("is_active")
  invitedById    String?  @map("invited_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

model Invitation {
  id             String    @id @default(cuid()) @map("id")
  organizationId String    @map("organization_id")
  email          String    @map("email")
  role           OrgRole   @map("role")
  token          String    @unique @map("token")
  invitedById    String    @map("invited_by")
  expiresAt      DateTime  @map("expires_at")
  acceptedAt     DateTime? @map("accepted_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationInvitedBy", fields: [invitedById], references: [id])

  @@map("invitations")
}

// ===== ESTOQUE DE VEÍCULOS =====

enum VehicleStatus {
  AVAILABLE
  RESERVED
  SOLD
  IN_PREPARATION
  IN_MAINTENANCE
  INACTIVE
}

enum FuelType {
  GASOLINE
  ETHANOL
  FLEX
  DIESEL
  ELECTRIC
  HYBRID
  CNG
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  SEMI_AUTOMATIC
}

enum BodyType {
  HATCH
  SEDAN
  SUV
  PICKUP
  MINIVAN
  COUPE
  CONVERTIBLE
  WAGON
  VAN
  OTHER
}

enum VehicleCategory {
  POPULAR
  MEDIUM
  LUXURY
  PREMIUM
  COMMERCIAL
}

model Vehicle {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Obrigatórios
  brand          String
  model          String
  salePriceCents Int          @map("sale_price_cents")

  // Opcionais — identificação
  version   String?
  year      Int?
  modelYear Int?    @map("model_year")

  // Opcionais — visuais
  exteriorColor String? @map("exterior_color")
  interiorColor String? @map("interior_color")

  // Opcionais — técnicos
  mileageKm    Int?                @map("mileage_km")
  fuelType     FuelType?           @map("fuel_type")
  transmission TransmissionType?
  bodyType     BodyType?           @map("body_type")
  category     VehicleCategory?
  engineSize   String?             @map("engine_size")
  doors        Int?

  // Opcionais — documentação
  licensePlate  String? @map("license_plate")
  chassisNumber String? @map("chassis_number")
  renavam       String?
  fipeCode      String? @map("fipe_code")

  // Opcionais — descrição e extras
  description String?  @db.Text
  optionals   String[] @default([])
  notes       String?  @db.Text

  // Custos
  acquisitionCostCents Int? @map("acquisition_cost_cents")
  minPriceCents        Int? @map("min_price_cents")
  fipePriceCents       Int? @map("fipe_price_cents")

  // Status e flags
  status     VehicleStatus @default(AVAILABLE)
  isComplete Boolean       @default(false) @map("is_complete")

  // Relacionamentos
  photos           VehiclePhoto[]
  costs            VehicleCost[]
  priceHistory     VehiclePriceHistory[]
  interestedLeads  Lead[]             @relation("LeadInterestVehicle")
  sales            Sale[]             @relation("SaleVehicle")

  // Auditoria
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([organizationId, status])
  @@index([organizationId, brand, model])
  @@index([organizationId, createdAt])
  @@index([organizationId, licensePlate])
  @@map("vehicles")
}

model VehiclePhoto {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicleId      String       @map("vehicle_id")
  vehicle        Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  url        String
  storageKey String  @map("storage_key")
  order      Int     @default(0)
  isCover    Boolean @default(false) @map("is_cover")

  mimeType  String? @map("mime_type")
  sizeBytes Int?    @map("size_bytes")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, vehicleId])
  @@index([vehicleId, order])
  @@map("vehicle_photos")
}

enum VehicleCostType {
  PURCHASE
  TRANSFER
  MECHANIC
  BODYWORK
  DETAILING
  INSPECTION
  PHOTOS
  CLEANING
  OTHER
}

model VehicleCost {
  id             String          @id @default(cuid())
  organizationId String          @map("organization_id")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicleId      String          @map("vehicle_id")
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type           VehicleCostType
  description    String
  amountCents    Int             @map("amount_cents")
  occurredAt     DateTime        @default(now()) @map("occurred_at")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, vehicleId])
  @@map("vehicle_costs")
}

model VehiclePriceHistory {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicleId      String       @map("vehicle_id")
  vehicle        Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  oldPriceCents Int?     @map("old_price_cents")
  newPriceCents Int      @map("new_price_cents")
  reason        String?
  changedBy     String?  @map("changed_by")
  changedAt     DateTime @default(now()) @map("changed_at")

  @@index([organizationId, vehicleId])
  @@index([vehicleId, changedAt])
  @@map("vehicle_price_history")
}

// ===== LEADS E CLIENTES =====

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  VISITING
  NEGOTIATING
  WON
  LOST
  ARCHIVED
}

enum LeadSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  WEBMOTORS
  OLX
  ICARROS
  MERCADO_LIVRE
  WEBSITE
  WALK_IN
  PHONE
  REFERRAL
  OTHER
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  HOT
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name    String
  cpfCnpj String? @map("cpf_cnpj")
  rg      String?
  birthDate DateTime? @map("birth_date")

  phone          String?
  phoneSecondary String? @map("phone_secondary")
  email          String?

  addressStreet       String? @map("address_street")
  addressNumber       String? @map("address_number")
  addressComplement   String? @map("address_complement")
  addressNeighborhood String? @map("address_neighborhood")
  addressCity         String? @map("address_city")
  addressState        String? @map("address_state")
  addressZip          String? @map("address_zip")

  occupation         String?
  monthlyIncomeCents Int?    @map("monthly_income_cents")
  employerName       String? @map("employer_name")

  notes String?  @db.Text
  tags  String[] @default([])

  leads Lead[]
  sales Sale[]

  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([organizationId, cpfCnpj])
  @@index([organizationId, phone])
  @@index([organizationId, email])
  @@map("customers")
}

// ===== VENDAS =====

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  DEBIT_CARD
  CREDIT_CARD
  FINANCING
  CONSORTIUM
  TRADE_IN_ONLY
  MIXED
}

model Sale {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation("SaleVehicle", fields: [vehicleId], references: [id])
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])
  leadId     String?  @unique @map("lead_id")
  lead       Lead?    @relation("SaleLead", fields: [leadId], references: [id])
  salesPersonId String @map("sales_person_id")
  salesPerson   User   @relation("SalesSalesPerson", fields: [salesPersonId], references: [id])

  listPriceCents  Int @map("list_price_cents")
  finalPriceCents Int @map("final_price_cents")
  discountCents   Int @default(0) @map("discount_cents")

  paymentMethod PaymentMethod @map("payment_method")
  paymentNotes  String?       @map("payment_notes") @db.Text

  hasTradeIn       Boolean @default(false) @map("has_trade_in")
  tradeInBrand     String? @map("trade_in_brand")
  tradeInModel     String? @map("trade_in_model")
  tradeInYear      Int?    @map("trade_in_year")
  tradeInMileageKm Int?    @map("trade_in_mileage_km")
  tradeInPlate     String? @map("trade_in_plate")
  tradeInValueCents Int?   @map("trade_in_value_cents")
  tradeInNotes     String? @map("trade_in_notes") @db.Text

  contractNumber String? @map("contract_number")
  notes          String? @db.Text

  status          SaleStatus @default(COMPLETED)
  soldAt          DateTime   @default(now()) @map("sold_at")
  cancelledAt     DateTime?  @map("cancelled_at")
  cancelledReason String?    @map("cancelled_reason")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status, soldAt])
  @@index([organizationId, salesPersonId, soldAt])
  @@index([organizationId, customerId])
  @@index([vehicleId])
  @@map("sales")
}

// ===== WHATSAPP / CANAIS DE MENSAGEM =====

enum ChannelProvider {
  UAZAPI

  @@map("channel_provider")
}

enum ChannelInstanceStatus {
  PENDING
  QR_REQUIRED
  CONNECTING
  CONNECTED
  DISCONNECTED
  ERROR
  INACTIVE

  @@map("channel_instance_status")
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  ARCHIVED

  @@map("conversation_status")
}

enum MessageDirection {
  INBOUND
  OUTBOUND

  @@map("message_direction")
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  LOCATION
  CONTACT
  STICKER
  SYSTEM
  UNKNOWN

  @@map("message_type")
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED

  @@map("message_status")
}

model ChannelInstance {
  id             String                @id @default(cuid())
  organizationId String                @map("organization_id")
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name     String
  provider ChannelProvider @default(UAZAPI)

  externalId     String? @map("external_id")
  baseUrl        String  @map("base_url")
  encryptedToken String? @map("encrypted_token")
  phoneNumber    String? @map("phone_number")
  profileName    String? @map("profile_name")

  status     ChannelInstanceStatus @default(PENDING)
  lastQrCode String?               @map("last_qr_code") @db.Text
  lastError  String?               @map("last_error") @db.Text
  lastConnectedAt    DateTime? @map("last_connected_at")
  lastDisconnectedAt DateTime? @map("last_disconnected_at")

  webhookSecret String @map("webhook_secret")

  conversations Conversation[]

  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([organizationId, status])
  @@index([webhookSecret])
  @@map("channel_instances")
}

model Conversation {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  channelInstanceId String          @map("channel_instance_id")
  channelInstance   ChannelInstance @relation(fields: [channelInstanceId], references: [id], onDelete: Cascade)

  externalChatId String  @map("external_chat_id")
  phoneNumber    String  @map("phone_number")
  contactName    String? @map("contact_name")
  contactAvatar  String? @map("contact_avatar")
  isGroup        Boolean @default(false) @map("is_group")

  leadId String? @map("lead_id")
  lead   Lead?   @relation("ConversationLead", fields: [leadId], references: [id], onDelete: SetNull)

  status           ConversationStatus @default(OPEN)
  assignedToId     String?            @map("assigned_to_id")
  assignedTo       User?              @relation("ConversationAssignedTo", fields: [assignedToId], references: [id])
  unreadCount      Int                @default(0) @map("unread_count")
  lastMessageAt    DateTime?          @map("last_message_at")
  lastMessagePreview String?         @map("last_message_preview")

  messages Message[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([channelInstanceId, externalChatId])
  @@index([organizationId, status, lastMessageAt])
  @@index([organizationId, leadId])
  @@index([organizationId, phoneNumber])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  externalMessageId String? @map("external_message_id")
  externalSender    String? @map("external_sender")

  direction MessageDirection
  type      MessageType
  text      String? @db.Text
  mediaUrl       String? @map("media_url")
  mediaMimeType  String? @map("media_mime_type")
  mediaCaption   String? @map("media_caption") @db.Text
  metadata Json?

  status       MessageStatus @default(PENDING)
  sentAt       DateTime?     @map("sent_at")
  deliveredAt  DateTime?     @map("delivered_at")
  readAt       DateTime?     @map("read_at")
  failedAt     DateTime?     @map("failed_at")
  errorMessage String?       @map("error_message") @db.Text

  sentByUserId String? @map("sent_by_user_id")
  sentBy       User?   @relation("MessageSentBy", fields: [sentByUserId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, conversationId, createdAt])
  @@index([externalMessageId])
  @@map("messages")
}

model Lead {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name  String
  phone String?
  email String?
  cpf   String?

  source        LeadSource @default(OTHER)
  sourceDetails String?    @map("source_details")
  assignedToId  String?    @map("assigned_to_id")
  assignedTo    User?      @relation("LeadAssignedTo", fields: [assignedToId], references: [id])

  status   LeadStatus   @default(NEW)
  priority LeadPriority @default(MEDIUM)
  tags     String[]     @default([])

  interestVehicleId   String?  @map("interest_vehicle_id")
  interestVehicle     Vehicle? @relation("LeadInterestVehicle", fields: [interestVehicleId], references: [id], onDelete: SetNull)
  interestDescription String?  @map("interest_description")

  hasTradeIn         Boolean @default(false) @map("has_trade_in")
  tradeInDescription String? @map("trade_in_description")

  budgetMinCents Int? @map("budget_min_cents")
  budgetMaxCents Int? @map("budget_max_cents")

  interactions LeadInteraction[]
  conversations Conversation[] @relation("ConversationLead")
  customerId   String?   @map("customer_id")
  customer     Customer? @relation(fields: [customerId], references: [id])
  sale         Sale?     @relation("SaleLead")

  lostReason    String?   @map("lost_reason")
  wonAt         DateTime? @map("won_at")
  lostAt        DateTime? @map("lost_at")
  lastContactAt DateTime? @map("last_contact_at")
  createdBy     String?   @map("created_by")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  @@index([organizationId, status])
  @@index([organizationId, assignedToId])
  @@index([organizationId, phone])
  @@index([organizationId, email])
  @@index([organizationId, createdAt])
  @@index([organizationId, customerId])
  @@map("leads")
}

enum LeadInteractionType {
  NOTE
  PHONE_CALL
  WHATSAPP_SENT
  WHATSAPP_RECEIVED
  EMAIL_SENT
  EMAIL_RECEIVED
  VISIT
  PROPOSAL_SENT
  TEST_DRIVE
  STATUS_CHANGE
  ASSIGNMENT
}

model LeadInteraction {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String       @map("lead_id")
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type     LeadInteractionType
  content  String              @db.Text
  metadata Json?

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, leadId, createdAt])
  @@map("lead_interactions")
}
